{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,

  "cli": {
    "packageManager": "npm",
    "analytics": false
  },

  "projects": {

    "bestearningapps-frontend": {

      "projectType": "application",

      "root": "",

      "sourceRoot": "src",

      "prefix": "app",

      "architect": {

        "build": {

          "builder": "@angular/build:application",

          "options": {

            "browser": "src/main.ts",

            "tsConfig": "tsconfig.app.json",

            "outputPath": "dist/bestearningapps-frontend/browser",

            "assets": [

              {
                "glob": "**/*",
                "input": "public"
              },

              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              },

              "src/favicon.ico",

              "src/sitemap.xml",

              "src/robots.txt"

            ],

            "styles": [
              "src/styles.css"
            ]

          },

          "configurations": {

            "production": {

              "outputHashing": "all",

              "optimization": true,

              "sourceMap": false,

              "extractLicenses": true,

              "namedChunks": false,

              "vendorChunk": false

            },

            "development": {

              "optimization": false,

              "sourceMap": true,

              "extractLicenses": false,

              "namedChunks": true,

              "vendorChunk": true

            }

          },

          "defaultConfiguration": "development"

        },

        "serve": {

          "builder": "@angular/build:dev-server",

          "configurations": {

            "development": {

              "buildTarget":
              "bestearningapps-frontend:build:development"

            },

            "production": {

              "buildTarget":
              "bestearningapps-frontend:build:production"

            }

          },

          "defaultConfiguration": "development"

        }

      }

    }

  }

}